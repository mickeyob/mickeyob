    {
      "cell_type": "markdown",
      "source": [
        "Creating training and testing iterable for traing and and evaluation"
      ],
      "metadata": {
        "id": "2eGrGhE6302q"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "train_data_loader = DataLoader(train_data,\n",
        "                               batch_size=32,\n",
        "                               shuffle=True)\n",
        "test_data_loader = DataLoader(test_data,\n",
        "                              batch_size=32,\n",
        "                              shuffle=False)"
      ],
      "metadata": {
        "id": "xhkeOjYGrKzQ"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "A function to calculate the training time of a model on a device (GPU or cpu)"
      ],
      "metadata": {
        "id": "ZLOnn8rE4Kxv"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "from timeit import default_timer as timer\n",
        "def print_train_time(start: float, end: float, device: torch.device = None):\n",
        "    total_time = end - start\n",
        "    print(f\"Train time on {device}: {total_time:.3f} seconds\")\n",
        "    return total_time"
      ],
      "metadata": {
        "id": "viS-A9CyxnYr"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "Creating the baseline model with linear layers, with no activation functions\n"
      ],
      "metadata": {
        "id": "CScCjMM4rca5"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "class BaseLineModel(nn.Module):\n",
        "  def __init__(self, input_shape, hidden_units, output_shape):\n",
        "    super().__init__()\n",
        "    self.layer_stack = nn.Sequential(\n",
        "        nn.Flatten(),\n",
        "        nn.Linear(in_features=input_shape, out_features=hidden_units),\n",
        "        nn.Linear(in_features=hidden_units, out_features=hidden_units),\n",
        "        nn.Linear(in_features=hidden_units, out_features=output_shape)\n",
        "    )\n",
        "  def forward(self, x):\n",
        "    return self.layer_stack(x)\n"
      ],
      "metadata": {
        "id": "HMPZnHYArpqc"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "torch.manual_seed(42)\n",
        "model_0 = BaseLineModel(input_shape=784,\n",
        "                        hidden_units=10,\n",
        "                        output_shape=len(class_names))"
      ],
      "metadata": {
        "id": "uweWVeEEsnTi"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "loss_fn = nn.CrossEntropyLoss()\n",
        "optimizer = torch.optim.SGD(params=model_0.parameters(), lr=0.1)"
      ],
      "metadata": {
        "id": "MYYgbu_NswGL"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "def accuracy_fn(y_true, y_pred):\n",
        "  correct = torch.eq(y_true, y_pred).sum().item()\n",
        "  acc = (correct / len(y_pred)) * 100\n",
        "  return acc"
      ],
      "metadata": {
        "id": "UjH6TBGts718"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "Creating a function for the training step"
      ],
      "metadata": {
        "id": "lbT5OQ2ksb7Q"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "torch.manual_seed(42)\n",
        "def train_step(model,\n",
        "               optimizer,\n",
        "               loss,\n",
        "               accuracy,\n",
        "               data_loader):\n",
        "  model.train()\n",
        "  train_loss = 0\n",
        "  train_acc = 0\n",
        "  for batch, (X,y) in enumerate(data_loader):\n",
        "    model.to(device)\n",
        "    X, y = X.to(device), y.to(device)\n",
        "    y_pred = model(X)\n",
        "    cost = loss(y_pred, y)\n",
        "    train_loss += cost.item()\n",
        "    train_acc += accuracy(y_true=y, y_pred=y_pred.argmax(dim=1))\n",
        "    optimizer.zero_grad()\n",
        "    cost.backward()\n",
        "    optimizer.step()\n",
        "  print(f\"Train loss: {train_loss/len(data_loader)} | Train accuracy: {train_acc/len(data_loader)}\")\n"
      ],
      "metadata": {
        "id": "TL_S-3LOsWai"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "Creating a function for evaluation"
      ],
      "metadata": {
        "id": "D3av-9n9ubIV"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "torch.manual_seed(42)\n",
        "def eval_step(model,\n",
        "              loss,\n",
        "              accuracy,\n",
        "              data_loader):\n",
        "  model.to(device)\n",
        "  model.eval()\n",
        "  test_loss = 0\n",
        "  test_acc = 0\n",
        "  with torch.inference_mode():\n",
        "    for X, y in data_loader:\n",
        "      X, y = X.to(device), y.to(device)\n",
        "      y_pred = model(X)\n",
        "      test_loss += loss(y_pred, y).item()\n",
        "      test_acc += accuracy(y_true=y, y_pred=y_pred.argmax(dim=1))\n",
        "    print(f\"Test loss: {test_loss/len(data_loader):.5f} | Test accuracy: {test_acc/len(data_loader):.5f}\")"
      ],
      "metadata": {
        "id": "aIKGsEiduZ4m"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "Training the Baseline model with 3 epochs"
      ],
      "metadata": {
